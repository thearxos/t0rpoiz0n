#!/usr/bin/env bash
# arxos-vpntor 0.0.1 - VPN -> Tor chain for ArxOS-AnonKit.
# Connects a VPN FIRST, then routes everything through Tor (VPN->Tor) so the ISP
# only ever sees encrypted VPN traffic and never learns you use Tor.
#
# Default free source = VPN Gate (https://www.vpngate.net) - an academic public VPN
# relay pool (Univ. of Tsukuba) with a documented API that returns ready-to-use
# OpenVPN configs (base64), no account or rotating password. We pick the fastest
# server (optionally by country), decode its .ovpn, connect, then start Tor.
#
#   arxos-vpntor                         auto: fastest VPN Gate server -> VPN -> Tor
#   arxos-vpntor --country US            prefer a country (US, JP, KR, DE, ...)
#   arxos-vpntor --own FILE.ovpn [--user U --pass P]   your own trusted VPN -> Tor
#   arxos-vpntor --stop                  tear down (Tor first, then VPN)
#   arxos-vpntor --status                show VPN + Tor state
#
# NOTE: free public VPNs are lower-trust (you trust the relay operator instead of
# your ISP). For serious OPSEC use your own VPN (--own) or an obfs4 bridge.
set -u
GR=$'\033[1;32m'; AC=$'\033[38;5;208m'; RD=$'\033[1;31m'; RS=$'\033[0m'
say(){ printf "  ${AC}>>${RS} %s\n" "$*"; }
ok(){  printf "  ${GR}[ok]${RS} %s\n" "$*"; }
err(){ printf "  ${RD}[xx]${RS} %s\n" "$*"; }
[ "$(id -u)" -eq 0 ] || { err "must run as root (the AnonKit GUI elevates with pkexec)"; exit 1; }

STATE=/run/arxos-vpntor; mkdir -p "$STATE"
need(){ command -v "$1" >/dev/null 2>&1; }
for p in openvpn curl python3; do need "$p" || { say "installing $p"; pacman -S --noconfirm --needed "$p" >/dev/null 2>&1; }; done

real_ip(){ curl -s --max-time 8 https://api.ipify.org 2>/dev/null; }
vpn_up(){ ip -o link show up 2>/dev/null | grep -qE ': (tun|wg|tap)[0-9]'; }

fetch_vpngate(){   # echoes the chosen server's country; writes $STATE/vpngate.ovpn
  local d="$STATE/vpngate"; rm -rf "$d"; mkdir -p "$d"
  say "fetching the VPN Gate public server list"
  curl -fsSL --max-time 25 -A 'Mozilla/5.0' 'https://www.vpngate.net/api/iphone/' -o "$d/list.csv" \
    || { err "could not reach vpngate.net"; return 1; }
  python3 - "$d/list.csv" "$d/vpngate.ovpn" "${COUNTRY:-}" <<'PY'
import csv, base64, sys
src, out, want = sys.argv[1], sys.argv[2], sys.argv[3].upper()
rows = list(csv.reader(open(src, encoding="utf-8", errors="ignore")))
hdr = [h.strip('*#') for h in rows[1]]
ci, cc, sp = hdr.index('OpenVPN_ConfigData_Base64'), hdr.index('CountryShort'), hdr.index('Speed')
def pick(filter_country):
    best = None
    for r in rows[2:]:
        if len(r) <= ci or len(r[ci]) < 200: continue
        if filter_country and r[cc].upper() != filter_country: continue
        try: spd = int(r[sp])
        except Exception: spd = 0
        if not best or spd > best[0]: best = (spd, r[ci], r[cc])
    return best
best = pick(want) or pick("")
if not best: sys.exit(1)
open(out, "w").write(base64.b64decode(best[1]).decode("latin1"))
print(best[2])
PY
  [ -f "$d/vpngate.ovpn" ] || { err "no usable VPN Gate server in the feed"; return 1; }
}

connect_vpn(){   # $1 ovpn  $2 creds(optional)
  local ovpn="$1" creds="${2:-}"
  say "connecting VPN: $(basename "$ovpn")"
  pkill -f 'openvpn --config' 2>/dev/null; sleep 1
  local args=(--config "$ovpn" --daemon --writepid "$STATE/openvpn.pid" --log "$STATE/openvpn.log" --auth-nocache --connect-retry-max 3 --redirect-gateway def1)
  [ -n "$creds" ] && args+=(--auth-user-pass "$creds")
  ( cd "$(dirname "$ovpn")" && openvpn "${args[@]}" )
  say "waiting for the tunnel to come up"
  local i; for i in $(seq 1 30); do vpn_up && { ok "VPN tunnel up"; return 0; }; sleep 1; done
  err "VPN did not come up - see $STATE/openvpn.log"; return 1
}

start(){
  local ovpn before after creds="" country
  before=$(real_ip); say "real IP (no VPN): ${before:-?}"
  if [ "${OWN:-}" ]; then
    case "$OWN" in *.zip)   # VPNBook ships zipped bundles - unpack and pick a tcp443 config
      need unzip || pacman -S --noconfirm --needed unzip >/dev/null 2>&1
      local ud="$STATE/own"; rm -rf "$ud"; mkdir -p "$ud"; unzip -o -q "$OWN" -d "$ud" 2>/dev/null
      OWN=$(ls "$ud"/*tcp443*.ovpn 2>/dev/null | head -1); [ -z "$OWN" ] && OWN=$(ls "$ud"/*.ovpn 2>/dev/null | head -1)
      [ -z "$OWN" ] && { err "no .ovpn inside $1"; exit 1; }; say "using $(basename "$OWN")" ;;
    esac
    ovpn="$OWN"
    if [ "${VUSER:-}" ]; then creds="$STATE/creds"; printf '%s\n%s\n' "$VUSER" "${VPASS:-}" > "$creds"; chmod 600 "$creds"; fi
  else
    country=$(fetch_vpngate) || exit 1
    ovpn="$STATE/vpngate/vpngate.ovpn"; say "selected a VPN Gate server in ${country:-?}"
    creds="$STATE/creds"; printf 'vpn\nvpn\n' > "$creds"; chmod 600 "$creds"   # VPN Gate accepts vpn/vpn
  fi
  connect_vpn "$ovpn" "$creds" || exit 1
  after=$(real_ip); say "IP through VPN: ${after:-?}"
  [ -n "$after" ] && [ "$after" = "$before" ] && err "warning: IP did not change - the VPN may not be routing"
  say "chaining into Tor (VPN -> Tor)"
  t0rpoiz0n -s || { err "Tor start failed"; exit 1; }
  ok "VPN -> Tor active. Your ISP sees only the VPN; Tor is hidden behind it."
  say "verify the whole chain:  sudo t0rpoiz0n --safe"
}

stop(){
  say "stopping Tor"; t0rpoiz0n -k 2>/dev/null
  say "stopping VPN"; pkill -f 'openvpn --config' 2>/dev/null
  [ -f "$STATE/openvpn.pid" ] && kill "$(cat "$STATE/openvpn.pid")" 2>/dev/null
  ok "VPN -> Tor torn down; back to clearnet"
}

case "${1:-}" in
  --stop)    stop ;;
  --status)  vpn_up && ok "VPN: up" || err "VPN: down"
             systemctl is-active tor-t0rpoiz0n >/dev/null 2>&1 && ok "Tor: active" || err "Tor: off" ;;
  --country) COUNTRY="${2:-}"; start ;;
  --own)     OWN="${2:-}"; shift 2 || true
             while [ $# -gt 0 ]; do case "$1" in --user) VUSER="$2"; shift 2;; --pass) VPASS="$2"; shift 2;; *) shift;; esac; done
             [ -n "${OWN:-}" ] || { err "--own needs a FILE.ovpn"; exit 1; }; start ;;
  --version|-V) echo "arxos-vpntor 0.0.1 (ArxOS)" ;;
  *)         start ;;
esac
