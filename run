#!/usr/bin/env bash
#
# t0rpoiz0n - Installer / Runner
# Author     : 0xb0rn3 | oxbv1
# Version    : 1.1.3
# Repository : github.com/0xb0rn3/t0rpoiz0n
#

# ── Colours ───────────────────────────────────────────────────────────────────

RED='\033[31m' GREEN='\033[32m' CYAN='\033[36m' YELLOW='\033[33m'
BOLD='\033[1m' RESET='\033[0m'

ok()   { echo -e "${GREEN}[✓] $*${RESET}"; }
info() { echo -e "${CYAN}[*] $*${RESET}"; }
warn() { echo -e "${YELLOW}[!] $*${RESET}"; }
err()  { echo -e "${RED}[✗] $*${RESET}"; }

# ── Paths / constants ─────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOL_SCRIPT="${SCRIPT_DIR}/t0rpoiz0n.py"
INSTALL_PATH="/usr/local/bin/t0rpoiz0n"
CONFIG_DIR="/etc/t0rpoiz0n"
UPDATE_STAMP="${CONFIG_DIR}/.last_update_check"
REPO_FILE="${CONFIG_DIR}/.repo_path"
VERSION="1.1.3"
GITHUB_REPO="0xb0rn3/t0rpoiz0n"
UPDATE_INTERVAL=86400   # 24 h

# ── Banner ────────────────────────────────────────────────────────────────────

banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'BANNER'
   /$$      /$$$$$$                                /$$            /$$$$$$
  | $$     /$$$_  $$                              |__/           /$$$_  $$
 /$$$$$$  | $$$$\ $$  /$$$$$$   /$$$$$$   /$$$$$$  /$$ /$$$$$$$$| $$$$\ $$ /$$$$$$$
|_  $$_/  | $$ $$ $$ /$$__  $$ /$$__  $$ /$$__  $$| $$|____ /$$/| $$ $$ $$| $$__  $$
  | $$    | $$\ $$$$| $$  \__/| $$  \ $$| $$  \ $$| $$   /$$$$/ | $$\ $$$$| $$  \ $$
  | $$ /$$| $$ \ $$$| $$      | $$  | $$| $$  | $$| $$  /$$__/  | $$ \ $$$| $$  | $$
  |  $$$$/|  $$$$$$/| $$      | $$$$$$$/|  $$$$$$/| $$ /$$$$$$$$|  $$$$$$/| $$  | $$
   \___/   \______/ |__/      | $$____/  \______/ |__/|________/ \______/ |__/  |__/
                              | $$
                              |__/
          TOR PROXY & MAC SPOOFING FRAMEWORK  ·  v1.1.3  ·  by oxbv1
BANNER
    echo -e "${RESET}"
}

# ── Helpers ───────────────────────────────────────────────────────────────────

require_root() {
    [[ $EUID -eq 0 ]] && return
    err "This script must be run as root"
    warn "Usage: sudo ./run [options]"
    exit 1
}

require_python() {
    command -v python3 &>/dev/null && return
    info "python3 not found — installing..."
    pacman -S --noconfirm python && ok "python3 installed"
}

iptables_flush() {
    # Try both backends; ignore errors
    for ipt in iptables-nft iptables-legacy iptables; do
        command -v "$ipt" &>/dev/null || continue
        $ipt -F             2>/dev/null || true
        $ipt -X             2>/dev/null || true
        $ipt -t nat -F      2>/dev/null || true
        $ipt -t nat -X      2>/dev/null || true
        $ipt -P INPUT   ACCEPT 2>/dev/null || true
        $ipt -P FORWARD ACCEPT 2>/dev/null || true
        $ipt -P OUTPUT  ACCEPT 2>/dev/null || true
    done
}

# ── Auto-update ───────────────────────────────────────────────────────────────

find_repo() {
    # Stored path
    if [[ -f "$REPO_FILE" ]]; then
        local p; p=$(cat "$REPO_FILE")
        [[ -d "$p/.git" ]] && echo "$p" && return 0
    fi
    # Current dir
    [[ -d "$SCRIPT_DIR/.git" ]] && echo "$SCRIPT_DIR" && return 0
    # Common locations
    for p in "/opt/t0rpoiz0n" "$HOME/t0rpoiz0n" "/usr/local/src/t0rpoiz0n"; do
        [[ -d "$p/.git" ]] && echo "$p" && return 0
    done
    return 1
}

latest_version() {
    local v
    v=$(curl -sf "https://api.github.com/repos/${GITHUB_REPO}/releases/latest" \
        | grep '"tag_name":' | sed -E 's/.*"v?([^"]+)".*/\1/')
    [[ -z "$v" ]] && \
    v=$(curl -sf "https://api.github.com/repos/${GITHUB_REPO}/tags" \
        | grep '"name":' | head -1 | sed -E 's/.*"v?([^"]+)".*/\1/')
    echo "$v"
}

# Returns 0=equal 1=a>b 2=a<b
version_gt() {
    [[ "$1" == "$2" ]] && return 0
    local IFS=. a=($1) b=($2) i
    for ((i=0; i<${#a[@]}; i++)); do
        local ai=${a[i]:-0} bi=${b[i]:-0}
        ((10#$ai > 10#$bi)) && return 1
        ((10#$ai < 10#$bi)) && return 2
    done
    return 0
}

perform_update() {
    local repo="$1"
    info "Pulling latest changes..."
    cd "$repo"
    git fetch origin || { err "git fetch failed"; return 1; }
    git pull origin main 2>/dev/null || git pull origin master 2>/dev/null \
        || { err "git pull failed"; return 1; }
    ok "Repository updated"

    if [[ -f "$INSTALL_PATH" ]]; then
        cp "${repo}/t0rpoiz0n.py" "$INSTALL_PATH"
        chmod +x "$INSTALL_PATH"
        "$INSTALL_PATH" --setup 2>/dev/null || true
        ok "Systemwide install refreshed"
    fi
}

check_updates() {
    # Honour --no-update-check flag
    for arg in "$@"; do [[ "$arg" == "--no-update-check" ]] && return 0; done

    # Rate-limit to once per 24 h
    if [[ -f "$UPDATE_STAMP" ]]; then
        local last now diff
        last=$(cat "$UPDATE_STAMP"); now=$(date +%s); diff=$((now - last))
        (( diff < UPDATE_INTERVAL )) && return 0
    fi

    local repo; repo=$(find_repo) || return 0
    mkdir -p "$CONFIG_DIR"
    echo "$SCRIPT_DIR" > "$REPO_FILE"

    ping -c1 github.com &>/dev/null || return 0

    info "Checking for updates..."
    local latest; latest=$(latest_version)
    [[ -z "$latest" ]] && { warn "Could not fetch version info"; date +%s > "$UPDATE_STAMP"; return 0; }

    version_gt "$VERSION" "$latest"
    local cmp=$?

    if [[ $cmp -eq 2 ]]; then
        echo -e "\n${YELLOW}${BOLD}Update available:${RESET} ${VERSION} → ${latest}"
        echo -n -e "${YELLOW}Update now? [y/N]: ${RESET}"
        read -r resp
        if [[ "$resp" =~ ^[Yy]$ ]]; then
            perform_update "$repo" \
                && { ok "Update complete — re-run the command"; exit 0; } \
                || warn "Update failed; continuing with $VERSION"
        fi
    elif [[ $cmp -eq 0 ]]; then
        ok "Already on latest version ($VERSION)"
    fi

    date +%s > "$UPDATE_STAMP"
}

# ── Install / uninstall ───────────────────────────────────────────────────────

install() {
    info "Installing t0rpoiz0n..."

    [[ -f "$TOOL_SCRIPT" ]] || { err "Cannot find t0rpoiz0n.py in $SCRIPT_DIR"; exit 1; }
    require_python

    mkdir -p "$CONFIG_DIR"
    echo "$SCRIPT_DIR" > "$REPO_FILE"

    cp "$TOOL_SCRIPT" "$INSTALL_PATH"
    chmod +x "$INSTALL_PATH"
    ok "Installed → $INSTALL_PATH"

    "$INSTALL_PATH" --setup

    echo
    ok "Installation complete"
    echo
    echo -e "${CYAN}Usage:${RESET}"
    echo -e "  sudo t0rpoiz0n -s              # start"
    echo -e "  sudo t0rpoiz0n -s -m -v apple  # start + spoof MAC"
    echo -e "  sudo t0rpoiz0n -c              # check status"
    echo -e "  sudo t0rpoiz0n -r              # new identity"
    echo -e "  sudo t0rpoiz0n -k              # stop"
    echo -e "  sudo t0rpoiz0n --setup         # re-run setup"
    echo
    echo -e "${CYAN}Vendors:${RESET} apple asus dell google hp huawei lenovo motorola nokia samsung"
    echo
}

uninstall() {
    info "Uninstalling t0rpoiz0n..."

    systemctl stop    tor-t0rpoiz0n.service 2>/dev/null || true
    systemctl disable tor-t0rpoiz0n.service 2>/dev/null || true

    rm -f  "$INSTALL_PATH"
    rm -f  /etc/systemd/system/tor-t0rpoiz0n.service
    rm -f  /etc/modules-load.d/iptables.conf
    rm -rf /usr/share/t0rpoiz0n
    rm -rf /var/lib/t0rpoiz0n
    rm -rf /etc/t0rpoiz0n
    systemctl daemon-reload

    iptables_flush
    ok "iptables restored"

    sysctl -w net.ipv6.conf.all.disable_ipv6=0     >/dev/null 2>&1 || true
    sysctl -w net.ipv6.conf.default.disable_ipv6=0 >/dev/null 2>&1 || true
    ok "IPv6 re-enabled"

    # Restore DNS if a backup exists
    if [[ -f /var/lib/t0rpoiz0n/backups/resolv.conf.backup ]]; then
        cp /var/lib/t0rpoiz0n/backups/resolv.conf.backup /etc/resolv.conf
        ok "DNS restored from backup"
    fi

    ok "Uninstall complete"
}

# ── Run locally (no install) ──────────────────────────────────────────────────

run_local() {
    [[ -f "$TOOL_SCRIPT" ]] || { err "Cannot find t0rpoiz0n.py in $SCRIPT_DIR"; exit 1; }
    require_python
    python3 "$TOOL_SCRIPT" "$@"
}

# ── Usage ─────────────────────────────────────────────────────────────────────

usage() {
    banner
    echo -e "${CYAN}USAGE${RESET}"
    echo -e "  sudo ./run --install      install system-wide"
    echo -e "  sudo ./run --uninstall    remove completely"
    echo -e "  sudo ./run [flags]        run without installing"
    echo
    echo -e "${CYAN}FLAGS (passed through to t0rpoiz0n)${RESET}"
    echo -e "  -s            start transparent proxy"
    echo -e "  -k            stop and restore clearnet"
    echo -e "  -r            new Tor circuit"
    echo -e "  -c            check status"
    echo -e "  -m            spoof MAC"
    echo -e "  -v VENDOR     MAC vendor prefix"
    echo -e "  -i IFACE      network interface"
    echo -e "  --no-update-check   skip the 24 h update check"
    echo
    echo -e "${CYAN}REPO${RESET}  github.com/0xb0rn3/t0rpoiz0n"
    echo
}

# ── Entry point ───────────────────────────────────────────────────────────────

main() {
    [[ $# -eq 0 ]] && { usage; exit 0; }
    [[ "$1" != "--help" && "$1" != "-h" ]] && require_root

    case "$1" in
        --install)   banner; install   ;;
        --uninstall) banner; uninstall ;;
        --help|-h)   usage             ;;
        *)
            banner
            check_updates "$@"
            run_local "$@"
            ;;
    esac
}

main "$@"
